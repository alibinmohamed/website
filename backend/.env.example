# ── Copy this file to .env and fill in your values ───────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local MySQL example:
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost/cyberclub

# Railway MySQL example:
# DATABASE_URL=mysql+pymysql://root:pass@containers-us-west-xx.railway.app:PORT/railway

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret:  python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_EXPIRES_HOURS=24

# ── Admin Password ────────────────────────────────────────────────────────────
# 1. Choose a strong admin password (e.g. "MySecurePass!2024")
# 2. Generate its bcrypt hash:
#    python3 -c "from flask_bcrypt import Bcrypt; b=Bcrypt(); print(b.generate_password_hash('MySecurePass!2024').decode())"
# 3. Paste the output below:
ADMIN_PASSWORD_HASH=$2b$12$examplehashgoeshere...

# ── Mail (Gmail example with App Password) ────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=your.email@gmail.com
ADMIN_EMAIL=mutawa510@gmail.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production, replace * with your actual frontend URL:
# CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=*
